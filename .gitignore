# ==========================================
# LifeMap .gitignore
# ==========================================

# ----------------------
# Python cache
# ----------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------
# Virtual environments
# ----------------------
venv/
.venv/
env/
ENV/

# ----------------------
# IDE
# ----------------------
.idea/
.vscode/
*.code-workspace

# ----------------------
# OS
# ----------------------
.DS_Store
Thumbs.db

# ----------------------
# Build / PyInstaller
# ----------------------
build/
dist/
*.spec
*.exe
*.app
*.dmg
*.manifest

# ----------------------
# Logs
# ----------------------
*.log

# ----------------------
# SQLite runtime DB
# ----------------------
*.db
*.sqlite
*.sqlite3

# Если база создаётся динамически
data/
instance/

# ----------------------
# FileService storage
# ----------------------
uploads/
files/
storage/

# ----------------------
# Testing / coverage
# ----------------------
.pytest_cache/
.cache/
.coverage
htmlcov/

# ----------------------
# Lint / type check
# ----------------------
.mypy_cache/
.ruff_cache/

# ----------------------
# Qt temporary
# ----------------------
.qt_for_python/

# ----------------------
# Legacy folder (FULL IGNORE)
# ----------------------
zoldik/

resources/styles/light_new.pss